%% TRIAGE-DP — abstract black-box operational model (Layers 1–4)
%% Layer 4 = EM-HSD v2. Edit at https://mermaid.js.org/

flowchart TB
  subgraph IN["Inputs"]
    I1["Text corpus (CSV)"]
    I2["Privacy–utility policy\n(calibrated offline, Layer 3)"]
  end

  subgraph CORE["TRIAGE-DP back-end (black box)"]
    direction TB
    A["Ingest & normalize"]
    B["Layer 1–2: analyze tokens\nroute hate vs identity risk"]
    C["Selective privatization\n(token-level)"]
    D["Layer 4 (EM-HSD v2)\nwhen sentence-level rewrite needed"]
    A --> B --> C
    C -->|most rows| E["Emit sanitized text"]
    C -->|hard rows| D --> E
  end

  subgraph SAFE["Embedded safeguards"]
    direction LR
    S1["Author-blind"]
    S2["Preserve hate signal"]
    S3["Audit trail"]
    S4["DP guarantees"]
  end

  subgraph OUT["Outputs"]
    O1["Privatized corpus"]
    O2["Decision logs"]
  end

  subgraph EVAL["Separate evaluator (not in back-end)"]
    R["Utility · Privacy · Trade-Off"]
  end

  I1 -->|text only| A
  I2 -.-> B
  I2 -.-> D
  SAFE -.-> CORE
  E --> O1 & O2
  I1 --> EVAL
  O1 --> EVAL
  EVAL --> R
